# EtherX local runtime configuration (example)
# Copy to .env.local for local dev, or let EtherX auto-generate runtime env files.
# This file is safe to commit because values are empty placeholders.

# TikTok AI license validation endpoint
ETHERX_TKAI_LICENSE_API_URL=https://kriptoentuzijasti.io/wp-json/ken-webshop/v1/license/validate

# Shared API key used by EtherX -> WordPress license endpoint
# Leave empty in repository. Set only in local/private environments.
ETHERX_TKAI_LICENSE_API_KEY=

# Optional comma/newline separated SHA-256 code hashes for static fallback
ETHERX_TKAI_VALID_HASHES=

# Optional admin device IDs (comma separated)
ETHERX_ADMIN_DEVICE_IDS=
