{
  "name": "etherx-standalone",
  "version": "2.4.29",
  "description": "EtherX Standalone Browser - Complete desktop + web version",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect=5858",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  },
  "author": {
    "name": "EtherX Team",
    "email": "info@kriptoentuzijasti.io",
    "url": "https://kriptoentuzijasti.io"
  },
  "homepage": "https://kriptoentuzijasti.io",
  "license": "MIT",
  "overrides": {
    "lzma-native": {
      "node-addon-api": "^7.1.0"
    }
  },
  "build": {
    "appId": "io.kriptoentuzijasti.etherx",
    "productName": "EtherX Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network",
      "maintainer": "EtherX Team <info@kriptoentuzijasti.io>"
    },
    "win": {
      "target": [
        "portable",
        "zip"
      ],
      "verifyUpdateCodeSignature": false,
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9"
  },
  "dependencies": {
    "@cliqz/adblocker-electron": "^1.26.8",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.6.2",
    "crypto-js": "^4.2.0",
    "electron-store": "^8.1.0",
    "ethers": "^6.13.0",
    "i18next": "^23.11.5",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0"
  },
  "buildTime": "2026-03-08T22:27:25Z"
}
